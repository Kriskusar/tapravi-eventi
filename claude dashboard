// ═══════════════════════════════════════════════════════════════════
// CALENDAR LAYOUT CONSTANTS
// All pixel math uses these — both time labels and event blocks.
// ═══════════════════════════════════════════════════════════════════
const CAL_START_H = 6;   // first hour shown (06:00)
const CAL_END_H   = 26;  // last hour shown  (02:00 next day = hour 26)
const PX_PER_MIN  = 1.6; // pixels per minute  →  96px per hour

// Converts a time string "HH:MM" → minutes-since-midnight
function t2m(t) {
  if (!t) return 0;
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}
// Handles events that cross midnight (end < start → add 24h)
function endM(startMins, endStr) {
  if (!endStr) return startMins + 60;
  let e = t2m(endStr);
  if (e <= startMins && startMins >= 12 * 60) e += 24 * 60;
  return e;
}
// Minutes → pixel offset from top of grid
function m2px(mins) {
  return (mins - CAL_START_H * 60) * PX_PER_MIN;
}
function m2str(mins) {
  const h = Math.floor(mins / 60) % 24;
  const m = mins % 60;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
}
const CAL_TOTAL_PX = (CAL_END_H - CAL_START_H) * 60 * PX_PER_MIN;

