// DAILY CALENDAR PAGE
// ═══════════════════════════════════════════════════════════
const CAL_START_H = 6;  // show from 6:00
const CAL_END_H   = 26; // show until 02:00 next day (hour 26)
const SLOT_H      = 48; // px per 30min slot

function timeToMinutes(t){
  if(!t)return 0;
  const [h,m]=(t||'0:0').split(':').map(Number);
  return h*60+m;
}
// For events ending past midnight, add 24h if endM < startM
function endTimeToMinutes(endT, startM){
  if(!endT) return startM+60;
  let endM = timeToMinutes(endT);
  // If end time is <= start time and start time is in PM (after noon),
  // event crosses midnight — add 24h to end time
  if(endM <= startM && startM >= 12*60) endM += 24*60;
  return endM;
}
function minutesToPx(mins){
  const startMins=CAL_START_H*60;
  return ((mins-startMins)/30)*SLOT_H;
}
function minutesToTime(mins){
  const h=Math.floor(mins/60)%24;
  const m=mins%60;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
}

function renderCalendar(e){
  const calEvents=(e.cal_events||[]).slice().sort((a,b)=>timeToMinutes(a.start)-timeToMinutes(b.start));
  const calDate=e.cal_date||'';

  // Stats
  const prog=calEvents.filter(x=>x.type==='program').length;
  const checks=calEvents.filter(x=>x.type==='check').length;
  const total=calEvents.length;

  // Build slot rows
  const slots=[];
  for(let h=CAL_START_H;h<CAL_END_H;h++){
    slots.push({mins:h*60,isHalf:false});
    slots.push({mins:h*60+30,isHalf:true});
  }
  const totalCalH=(CAL_END_H-CAL_START_H)*SLOT_H*2;

  // Now line
  const now=new Date();
  const nowMins=now.getHours()*60+now.getMinutes();
  const nowPx=minutesToPx(nowMins);
  const showNowLine=nowMins>=CAL_START_H*60&&nowMins<CAL_END_H*60;

  // Build event blocks with collision detection
  const visibleEvs = calEvents.filter(ev=>typeFilter[ev.type]!==false).map(ev=>{
    const startM=timeToMinutes(ev.start);
    const endM=endTimeToMinutes(ev.end,startM);
    return {...ev,startM,endM};
  });
  // Assign columns to avoid overlap
  const cols=[];
  visibleEvs.forEach(ev=>{
    let placed=false;
    for(let c=0;c<cols.length;c++){
      const last=cols[c][cols[c].length-1];
      if(ev.startM>=last.endM){cols[c].push(ev);ev._col=c;placed=true;break;}
    }
    if(!placed){cols.push([ev]);ev._col=cols.length-1;}
  });
  // For each event, find total columns that overlap with it
  visibleEvs.forEach(ev=>{
    let maxCols=1;
    visibleEvs.forEach(other=>{
      if(other.id===ev.id)return;
      const overlaps=ev.startM<other.endM&&ev.endM>other.startM;
      if(overlaps) maxCols=Math.max(maxCols,other._col+1,ev._col+1);
    });
    ev._totalCols=maxCols;
  });

  let eventBlocksHtml='';
  visibleEvs.forEach(ev=>{
    const top=minutesToPx(ev.startM);
    const height=Math.max(36,minutesToPx(ev.endM)-top);
    const color=CAL_TYPE_COLORS[ev.type]||'#ffcb05';
    const mem=(e.team||[]).find(m=>m.id===ev.person);
    const emoji=CAL_TYPE_LABELS[ev.type]||'📌';
    const bg=ev.type==='program'?color:`rgba(${hexToRgb(color)},.18)`;
    const textColor=ev.type==='program'?'#111':'var(--text)';
    const totalCols=ev._totalCols||1;
    const col=ev._col||0;
    const pct100=100/totalCols;
    const leftPct=col*pct100;
    const widthPct=pct100;
    const durationMins=ev.endM-ev.startM;
    const showNotes=durationMins>=30&&ev.notes;
    const showPerson=durationMins>=20&&mem;
    eventBlocksHtml+=`<div class="cal-event-block"
      style="top:${top}px;height:${height}px;left:calc(${leftPct}% + 3px);width:calc(${widthPct}% - 6px);right:auto;background:${bg};color:${textColor};border-left-color:${color};"
      onclick="openCalEventEdit('${e.id}','${ev.id}')">
      <div class="cal-event-title">${emoji} ${escH(ev.title)}</div>
      <div style="font-size:10px;opacity:.7;font-family:'DM Mono',monospace;margin-top:1px">${ev.start}${ev.end?'–'+ev.end:''}</div>
      ${showPerson?`<div class="cal-event-person" style="color:${mem.color}">👤 ${mem.name}</div>`:''}
      ${showNotes?`<div class="cal-event-notes">${escH(ev.notes.slice(0,70))}${ev.notes.length>70?'…':''}</div>`:''}
    </div>`;
  });

  // Build time column
  let timeColHtml='';
  slots.forEach(slot=>{
    const displayH=Math.floor(slot.mins/60);
    const displayM=slot.mins%60;
    const label=displayM===0?`${String(displayH%24).padStart(2,'0')}:00`:'';
    timeColHtml+=`<div class="${slot.isHalf?'cal-time-label half':'cal-time-label'}">${label}</div>`;
  });

  // Build grid lines
  let gridHtml='';
  slots.forEach(slot=>{
    const top=minutesToPx(slot.mins);
    const cls=slot.isHalf?'half':'';
    gridHtml+=`<div class="cal-slot ${cls}" style="position:absolute;left:0;right:0;top:${top}px;height:${SLOT_H}px;border-bottom:1px ${slot.isHalf?'dashed':'solid'} var(--border);cursor:pointer;" 
      onclick="openCalSlot('${e.id}',${slot.mins})"></div>`;
  });

  return `
  <!-- CAL HEADER -->
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:11px;font-weight:700;color:var(--muted)">DATUM:</span>
      <input class="cal-date-input" type="date" value="${calDate}" onchange="upCalDate('${e.id}',this.value)"/>
    </div>
    <div style="display:flex;gap:8px">
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Program: </span><span style="color:var(--yellow);font-weight:800;font-family:'DM Mono'">${prog}</span></div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Kontrole: </span><span style="color:#94a3b8;font-weight:800;font-family:'DM Mono'">${checks}</span></div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Skupaj: </span><span style="font-weight:800;font-family:'DM Mono'">${total}</span></div>
    </div>
    <button class="btn-sm primary" onclick="openCalSlot('${e.id}',1140)" style="margin-left:auto">＋ Dodaj vnos</button>
  </div>

  <!-- LEGEND -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center">
    <span style="font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;margin-right:2px">Filtri:</span>
    ${Object.entries(CAL_TYPE_COLORS).map(([k,c])=>{
      const active=typeFilter[k]!==false;
      const cnt=calEvents.filter(x=>x.type===k).length;
      return `<div onclick="toggleTypeFilter('${k}')" style="display:flex;align-items:center;gap:5px;font-size:11px;font-weight:700;cursor:pointer;padding:5px 10px;border-radius:20px;border:1.5px solid ${active?c:'transparent'};background:${active?`rgba(${hexToRgb(c)},.18)`:'var(--surface2)'};color:${active?c:'var(--muted)'};opacity:${active?'1':'.55'};transition:all .13s" title="${active?'Skrij':'Pokaži'} ${k}">
        <div style="width:10px;height:10px;border-radius:3px;background:${c};${active?'':'opacity:.4'}"></div>
        ${CAL_TYPE_LABELS[k]} ${k.charAt(0).toUpperCase()+k.slice(1)}
        <span style="font-family:'DM Mono',monospace;font-size:10px;opacity:.7">${cnt}</span>
      </div>`;
    }).join('')}
  </div>

  <!-- CALENDAR GRID -->
  <div style="display:flex;gap:0;border:1px solid var(--border);border-radius:11px;overflow:hidden;background:var(--surface)">
    <!-- Time column -->
    <div style="width:58px;flex-shrink:0;border-right:1px solid var(--border);background:var(--surface2)">
      ${timeColHtml}
    </div>
    <!-- Events column -->
    <div style="flex:1;position:relative;min-height:${totalCalH}px">
      ${gridHtml}
      ${showNowLine?`<div class="cal-now-line" style="top:${nowPx}px" title="Zdaj: ${minutesToTime(nowMins)}"></div>`:''}
      ${eventBlocksHtml}
    </div>
  </div>
  <div style="margin-top:10px;font-size:11px;color:var(--muted);text-align:center">Klikni na prazen termin za nov vnos · Klikni na blok za urejanje</div>`;
}

function hexToRgb(hex){
  const r=parseInt(hex.slice(1,3),16);
  const g=parseInt(hex.slice(3,5),16);
  const b=parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

function upCalDate(evId,val){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  e.cal_date=val;save();
}

// Open slot for new event
function openCalSlot(evId,mins){
  calEditId=null;calEditSlotTime=mins;calEditType='program';
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  document.getElementById('cal-modal-title').textContent='Nov vnos v časovnico';
  document.getElementById('cal-ev-title').value='';
  document.getElementById('cal-ev-start').value=minutesToTime(mins);
  document.getElementById('cal-ev-end').value=minutesToTime(mins+60);
  document.getElementById('cal-ev-notes').value='';
  document.getElementById('cal-ev-del').style.display='none';
  populateCalPersonSelect(e,'');
  selectCalType('program');
  document.getElementById('modal-cal-ev').style.display='flex';
}

// Open existing event for edit
function openCalEventEdit(evId,calId){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const ev=(e.cal_events||[]).find(x=>x.id===calId);if(!ev)return;
  calEditId=calId;calEditType=ev.type||'program';
  document.getElementById('cal-modal-title').textContent='Uredi vnos';
  document.getElementById('cal-ev-title').value=ev.title||'';
  document.getElementById('cal-ev-start').value=ev.start||'';
  document.getElementById('cal-ev-end').value=ev.end||'';
  document.getElementById('cal-ev-notes').value=ev.notes||'';
  document.getElementById('cal-ev-del').style.display='flex';
  populateCalPersonSelect(e,ev.person||'');
  selectCalType(ev.type||'program');
  document.getElementById('modal-cal-ev').style.display='flex';
}

function populateCalPersonSelect(e,selectedId){
  const sel=document.getElementById('cal-ev-person');
  sel.innerHTML='<option value="">— Brez —</option>'+(e.team||[]).map(m=>`<option value="${m.id}" ${m.id===selectedId?'selected':''}>${m.name}</option>`).join('');
}

function selectCalType(type){
  calEditType=type;
  document.querySelectorAll('.type-chip').forEach(c=>{
    const t=c.dataset.type;
    const color=CAL_TYPE_COLORS[t]||'#fff';
    c.style.borderColor=t===type?color:'transparent';
    c.style.background=t===type?`rgba(${hexToRgb(color)},.25)`:`rgba(${hexToRgb(color||'#888')},.08)`;
  });
}

function saveCalEvent(){
  const e=ce();if(!e)return;
  if(!e.cal_events)e.cal_events=[];
  const title=document.getElementById('cal-ev-title').value.trim();
  if(!title){alert('Vpiši naslov');return;}
  const start=document.getElementById('cal-ev-start').value;
  const end=document.getElementById('cal-ev-end').value;
  const notes=document.getElementById('cal-ev-notes').value;
  const person=document.getElementById('cal-ev-person').value;
  if(calEditId){
    const ev=e.cal_events.find(x=>x.id===calEditId);
    if(ev){ev.title=title;ev.start=start;ev.end=end;ev.type=calEditType;ev.notes=notes;ev.person=person;}
  } else {
    e.cal_events.push({id:uid(),title,start,end,type:calEditType,notes,person});
  }
  save();closeModal('modal-cal-ev');renderPage();toast('Shranjeno ✓');
}

function deleteCalEvent(){
  const e=ce();if(!e||!calEditId)return;
  e.cal_events=(e.cal_events||[]).filter(x=>x.id!==calEditId);
  save();closeModal('modal-cal-ev');renderPage();
}

