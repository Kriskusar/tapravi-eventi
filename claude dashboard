function addMember()      { const e=ce(); if(!e)return; const name=document.getElementById('new-member').value.trim(); if(!name)return; const color=AVATAR_COLORS[((e.team||[]).length)%AVATAR_COLORS.length]; if(!e.team)e.team=[]; e.team.push({id:uid(),name,color}); save(); renderTeamModal(e); renderPage(); document.getElementById('new-member').value=''; toast('Član dodan ✓'); }
function renameM(evId,mId,name) { const e=S.events.find(x=>x.id===evId); if(!e)return; const m=(e.team||[]).find(x=>x.id===mId); if(!m)return; m.name=name; save(); renderPage(); }
function setMColor(evId,mId,color) { const e=S.events.find(x=>x.id===evId); if(!e)return; const m=(e.team||[]).find(x=>x.id===mId); if(!m)return; m.color=color; save(); renderTeamModal(e); renderPage(); }
function delMember(evId,mId) { const e=S.events.find(x=>x.id===evId); if(!e)return; e.team=(e.team||[]).filter(m=>m.id!==mId); e.tasks.forEach(t=>{if(Array.isArray(t.odgovoren))t.odgovoren=t.odgovoren.filter(id=>id!==mId);}); save(); renderTeamModal(e); renderPage(); }

