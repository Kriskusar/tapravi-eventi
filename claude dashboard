function uid()    { return Math.random().toString(36).slice(2, 9); }
function escH(s)  { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function initials(n){ return (n||'?').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }
function hexRgb(hex){ return [1,3,5].map(i=>parseInt(hex.slice(i,i+2),16)).join(','); }

function makeTasks()  { return SECTIONS.flatMap(s => s.tasks.map(t => ({id:uid(), section:s.id, odgovoren:[], od:'', do:'', kaj:t, status:'todo', notes:''}))); }
function makeNH()     { return DEFAULT_NAB_HRANA.map(r => ({...r, id:uid()})); }
function makeNP()     { return DEFAULT_NAB_PIJACA.map(r => ({...r, id:uid()})); }
function makeCalEvs() { return DEFAULT_CAL_EVENTS.map(r => ({...r, id:uid()})); }

function getAssigned(t) {
  if (Array.isArray(t.odgovoren)) return t.odgovoren;
  if (typeof t.odgovoren === 'string' && t.odgovoren) return [t.odgovoren];
  return [];
}

