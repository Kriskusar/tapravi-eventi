// ── PERSON DROPDOWN — fixed-position portal ──────────────────
let _dropEvId=null, _dropTaskId=null;
function toggleDrop(evt,evId,taskId){
  evt.stopPropagation();
  // If same button clicked again, close
  if(_dropTaskId===taskId && document.getElementById('person-portal')?.classList.contains('open')){
    closeAllDrops(); return;
  }
  _dropEvId=evId; _dropTaskId=taskId;
  const e=S.events.find(x=>x.id===evId); if(!e)return;
  const t=e.tasks.find(x=>x.id===taskId); if(!t)return;
  const team=e.team||[];
  const assigned=getOdgovornArr(t);
  // Build portal HTML
  const items = team.map(m=>{
    const sel=assigned.includes(m.id);
    return `<div class="pd-item ${sel?'pd-selected':''}" onclick="togglePersonInTask(event,'${evId}','${taskId}','${m.id}')">
      <div class="pavatar" style="background:${m.color};color:#111;width:24px;height:24px;font-size:10px">${initials(m.name)}</div>
      <span style="flex:1">${m.name}</span>
      <div style="width:16px;height:16px;border-radius:4px;border:1.5px solid ${sel?'var(--yellow)':'var(--border)'};background:${sel?'var(--yellow)':'transparent'};display:flex;align-items:center;justify-content:center;flex-shrink:0">
        ${sel?'<span style="color:#111;font-size:10px;font-weight:800">✓</span>':''}
      </div>
    </div>`;
  }).join('');
  let portal=document.getElementById('person-portal');
  if(!portal){portal=document.createElement('div');portal.id='person-portal';document.body.appendChild(portal);}
  portal.innerHTML=`
    <div class="pd-clear" onclick="clearAllPersons(event,'${evId}','${taskId}')">✕ Počisti vse</div>
    ${items}
  `;
  // Position near the button
  const btn=document.getElementById('pbtn-'+taskId);
  if(btn){
    const r=btn.getBoundingClientRect();
    let top=r.bottom+4, left=r.left;
    // Keep in viewport
    if(left+180>window.innerWidth) left=window.innerWidth-188;
    if(top+300>window.innerHeight) top=r.top-Math.min(300,r.top-8);
    portal.style.top=top+'px'; portal.style.left=left+'px';
  }
  portal.classList.add('open');
  openDrop=taskId;
}
function togglePersonInTask(evt,evId,taskId,mId){
  evt.stopPropagation();
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const t=e.tasks.find(x=>x.id===taskId);if(!t)return;
  let arr=getOdgovornArr(t);
  if(arr.includes(mId)) arr=arr.filter(x=>x!==mId);
  else arr=[...arr,mId];
  t.odgovoren=arr; save();
  // Update button display
  refreshPersonBtn(evId,taskId);
  // Refresh portal checkboxes in place
  const team=e.team||[];
  const assigned=getOdgovornArr(t);
  document.querySelectorAll('#person-portal .pd-item').forEach(el=>{
    const onc=el.getAttribute('onclick')||'';
    const midMatch=onc.match(/'([^']+)'[^)]*\)$/);
    if(!midMatch)return;
    const mid=midMatch[1];
    const sel=assigned.includes(mid);
    const mem=team.find(m=>m.id===mid);
    el.classList.toggle('pd-selected',sel);
    const box=el.querySelector('div:last-child');
    if(box){box.style.borderColor=sel?'var(--yellow)':'var(--border)';box.style.background=sel?'var(--yellow)':'transparent';box.innerHTML=sel?'<span style="color:#111;font-size:10px;font-weight:800">✓</span>':'';}
  });
  // Update filter data
  const row=document.getElementById('row-'+taskId);
  if(row){const mems=arr.map(id=>(e.team||[]).find(m=>m.id===id)).filter(Boolean);row.dataset.odgovoren=mems.map(m=>m.name).join(', ');}
  renderSidebar();
}
function clearAllPersons(evt,evId,taskId){
  evt.stopPropagation();
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const t=e.tasks.find(x=>x.id===taskId);if(!t)return;
  t.odgovoren=[]; save();
  refreshPersonBtn(evId,taskId);
  closeAllDrops();
  const row=document.getElementById('row-'+taskId);if(row)row.dataset.odgovoren='';
  renderSidebar();
}
function refreshPersonBtn(evId,taskId){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const t=e.tasks.find(x=>x.id===taskId);if(!t)return;
  const team=e.team||[];
  const assigned=getOdgovornArr(t);
  const members=assigned.map(id=>team.find(m=>m.id===id)).filter(Boolean);
  const btn=document.getElementById('pbtn-'+taskId);
  if(!btn)return;
  if(members.length===0){btn.innerHTML='<span class="pempty">— Izberi —</span>';return;}
  btn.innerHTML=`<div style="display:flex;align-items:center;gap:2px;flex-wrap:wrap">${members.map(m=>`<div class="pavatar" style="background:${m.color};color:#111;margin-right:2px" title="${m.name}">${initials(m.name)}</div>`).join('')}<span style="font-size:11px;margin-left:2px">${members.length===1?members[0].name:members.map(m=>m.name).join(', ')}</span></div>`;
}
