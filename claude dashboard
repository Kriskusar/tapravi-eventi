// PERSON DROPDOWN (fixed portal)
// ═══════════════════════════════════════════════════════════════════
function toggleDrop(evt, evId, taskId) {
  evt.stopPropagation();
  const portal = document.getElementById('person-portal');
  if (_dropTaskId === taskId && portal.classList.contains('open')) { closeAllDrops(); return; }
  _dropEvId = evId; _dropTaskId = taskId;
  const e = S.events.find(x => x.id===evId); if(!e) return;
  const t = e.tasks.find(x => x.id===taskId); if(!t) return;
  const assigned = getAssigned(t);
  portal.innerHTML =
    `<div class="pd-clear" onclick="clearAllPersons(event,'${evId}','${taskId}')">✕ Počisti vse</div>` +
    (e.team||[]).map(m => {
      const sel = assigned.includes(m.id);
      return `<div class="pd-item" onclick="togglePersonInTask(event,'${evId}','${taskId}','${m.id}')">
        <div class="pavatar" style="background:${m.color};color:#111;width:24px;height:24px;font-size:10px">${initials(m.name)}</div>
        <span style="flex:1">${m.name}</span>
        <div style="width:16px;height:16px;border-radius:4px;border:1.5px solid ${sel?'var(--yellow)':'var(--border)'};background:${sel?'var(--yellow)':'transparent'};display:flex;align-items:center;justify-content:center">
          ${sel?'<span style="color:#111;font-size:10px;font-weight:800">✓</span>':''}
        </div>
      </div>`;
    }).join('');
  const btn  = document.getElementById('pbtn-'+taskId);
  if (btn) {
    const r  = btn.getBoundingClientRect();
    let top  = r.bottom + 4;
    let left = r.left;
    if (left + 200 > window.innerWidth) left = window.innerWidth - 208;
    if (top  + 300 > window.innerHeight) top = r.top - Math.min(300, r.top - 8);
    portal.style.top  = top  + 'px';
    portal.style.left = left + 'px';
  }
  portal.classList.add('open');
}

function togglePersonInTask(evt, evId, taskId, mId) {
  evt.stopPropagation();
  const e = S.events.find(x => x.id===evId); if(!e) return;
  const t = e.tasks.find(x => x.id===taskId); if(!t) return;
  let arr = getAssigned(t);
  arr = arr.includes(mId) ? arr.filter(x=>x!==mId) : [...arr, mId];
  t.odgovoren = arr; save();
  refreshPersonBtn(evId, taskId);
  // Refresh checkboxes in-place
  const team     = e.team||[];
  const assigned = getAssigned(t);
  document.querySelectorAll('#person-portal .pd-item').forEach(el => {
    const match = (el.getAttribute('onclick')||'').match(/'([^']+)'[^)]*\)$/);
    if (!match) return;
    const mid = match[1];
    const sel = assigned.includes(mid);
    const mem = team.find(m => m.id===mid);
    const box = el.querySelector('div:last-child');
    if (box) { box.style.borderColor=sel?'var(--yellow)':'var(--border)'; box.style.background=sel?'var(--yellow)':'transparent'; box.innerHTML=sel?'<span style="color:#111;font-size:10px;font-weight:800">✓</span>':''; }
  });
  const row = document.getElementById('row-'+taskId);
  if (row) { const ms=arr.map(id=>(e.team||[]).find(m=>m.id===id)).filter(Boolean); row.dataset.odgovoren=ms.map(m=>m.name).join(','); }
  renderSidebar();
}

function clearAllPersons(evt, evId, taskId) {
  evt.stopPropagation();
  const e = S.events.find(x => x.id===evId); if(!e) return;
  const t = e.tasks.find(x => x.id===taskId); if(!t) return;
  t.odgovoren = []; save(); refreshPersonBtn(evId, taskId); closeAllDrops();
  const row = document.getElementById('row-'+taskId); if(row) row.dataset.odgovoren='';
  renderSidebar();
}

function refreshPersonBtn(evId, taskId) {
  const e = S.events.find(x => x.id===evId); if(!e) return;
  const t = e.tasks.find(x => x.id===taskId); if(!t) return;
  const members = getAssigned(t).map(id => (e.team||[]).find(m=>m.id===id)).filter(Boolean);
  const btn = document.getElementById('pbtn-'+taskId); if(!btn) return;
  btn.innerHTML = members.length
    ? `<div style="display:flex;align-items:center;gap:2px;flex-wrap:wrap">${members.map(m=>`<div class="pavatar" style="background:${m.color};color:#111" title="${m.name}">${initials(m.name)}</div>`).join('')}<span style="font-size:11px;margin-left:3px">${members.map(m=>m.name).join(', ')}</span></div>`
    : `<span class="pempty">— Izberi —</span>`;
}

function closeAllDrops() {
  const p = document.getElementById('person-portal'); if(p) p.classList.remove('open');
  _dropEvId = null; _dropTaskId = null;
}
document.addEventListener('click', closeAllDrops);

// ═══════════════════════════════════════════════════════════════════
// UPDATE HELPERS
// ═══════════════════════════════════════════════════════════════════
function upPodatki(evId,key,val)  { const e=S.events.find(x=>x.id===evId); if(!e)return; if(!e.podatki)e.podatki={}; e.podatki[key]=val; save(); renderSidebar(); }
function upTask(evId,tId,field,val){ const e=S.events.find(x=>x.id===evId); if(!e)return; const t=e.tasks.find(x=>x.id===tId); if(!t)return; t[field]=val; save(); if(field==='od'){const r=document.getElementById('row-'+tId); if(r)r.dataset.cas=val;} }
function upStatus(evId,tId,sel)   { const e=S.events.find(x=>x.id===evId); if(!e)return; const t=e.tasks.find(x=>x.id===tId); if(!t)return; t.status=sel.value; sel.className='ssel '+({todo:'s-todo',inprogress:'s-inprogress',done:'s-done',blocked:'s-blocked'}[sel.value]||'s-todo'); const r=document.getElementById('row-'+tId); if(r)r.dataset.status=sel.value; save(); refreshStats(evId); }

function refreshStats(evId) {
  const e=S.events.find(x=>x.id===evId); if(!e)return;
  const p=pct(e),tot=e.tasks.length,done=e.tasks.filter(t=>t.status==='done').length,inp=e.tasks.filter(t=>t.status==='inprogress').length,blk=e.tasks.filter(t=>t.status==='blocked').length;
  const V=document.querySelectorAll('.stat-val'); if(V[0])V[0].textContent=p+'%'; if(V[1])V[1].textContent=inp; if(V[2])V[2].textContent=blk; if(V[3])V[3].textContent=tot;
  const sub=document.querySelectorAll('.stat-sub'); if(sub[0])sub[0].textContent=done+'/'+tot+' nalog';
  const fill=document.querySelector('.pbar-fill'); if(fill)fill.style.width=p+'%';
  renderSidebar();
  SECTIONS.forEach(s=>{const b=document.querySelector(`#card-${evId}-${s.id} .sec-badge`); if(b){const st=e.tasks.filter(t=>t.section===s.id); b.textContent=st.filter(t=>t.status==='done').length+'/'+st.length;}});
}

function addTask(evId,secId)      { const e=S.events.find(x=>x.id===evId); if(!e)return; const t={id:uid(),section:secId,odgovoren:[],od:'',do:'',kaj:'Nova naloga',status:'todo',notes:''}; e.tasks.push(t); save(); const tbody=document.querySelector(`#tbl-${evId}-${secId} tbody`); if(tbody)tbody.insertAdjacentHTML('beforeend',renderRow(evId,t,e.team||[])); refreshStats(evId); }
function delTask(evId,tId)        { const e=S.events.find(x=>x.id===evId); if(!e)return; e.tasks=e.tasks.filter(t=>t.id!==tId); const r=document.getElementById('row-'+tId); if(r)r.remove(); save(); refreshStats(evId); }

function upNab(evId,fk,iId,field,val)        { const e=S.events.find(x=>x.id===evId); if(!e)return; const i=(e[fk]||[]).find(x=>x.id===iId); if(!i)return; i[field]=val; save(); }
function upNabCena(evId,fk,iId,field,val)    { const e=S.events.find(x=>x.id===evId); if(!e)return; const i=(e[fk]||[]).find(x=>x.id===iId); if(!i)return; i[field]=val; const k=parseFloat(i.kolicina||0),c=parseFloat(i.cena_enota||0); if(k&&c){i.cena_skupaj=(k*c).toFixed(2); const el=document.getElementById('cs-'+iId); if(el)el.value=i.cena_skupaj;} save(); }
function addNabRow(evId,fk)                  { const e=S.events.find(x=>x.id===evId); if(!e)return; if(!e[fk])e[fk]=[]; const i={id:uid(),artikel:'',kolicina:'',enota:'',dobavitelj:'',cena_enota:'',cena_skupaj:'',naroceno:false,dostavljeno:false,notes:''}; e[fk].push(i); save(); const tbody=document.querySelector('#nab-tbl-'+(fk.includes('hrana')?'hrana':'pijaca')+' tbody'); if(tbody)tbody.insertAdjacentHTML('beforeend',renderNabRow(evId,fk,i)); }
function delNabRow(evId,fk,iId)              { const e=S.events.find(x=>x.id===evId); if(!e)return; e[fk]=(e[fk]||[]).filter(x=>x.id!==iId); const r=document.getElementById('nrow-'+iId); if(r)r.remove(); save(); }

function upStr(evId,iId,field,val)  { const e=S.events.find(x=>x.id===evId); if(!e)return; const i=(e.stroski||[]).find(x=>x.id===iId); if(!i)return; i[field]=val; save(); }
function addStrosek(evId)           { const e=S.events.find(x=>x.id===evId); if(!e)return; if(!e.stroski)e.stroski=[]; const i={id:uid(),opis:'',kategorija:'',znesek:'',datum:'',dobavitelj:'',placano:false,notes:''}; e.stroski.push(i); save(); const tbody=document.querySelector('#str-tbl tbody'); if(tbody)tbody.insertAdjacentHTML('beforeend',renderStrosekRow(evId,i)); }
function delStr(evId,iId)           { const e=S.events.find(x=>x.id===evId); if(!e)return; e.stroski=(e.stroski||[]).filter(x=>x.id!==iId); const r=document.getElementById('srow-'+iId); if(r)r.remove(); save(); }

// ═══════════════════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════════════════
function toggleCard(hd) { const b=hd.nextElementSibling; const c=hd.querySelector('.chev'); const o=b.style.display!=='none'; b.style.display=o?'none':'block'; hd.classList.toggle('open',!o); c.classList.toggle('open',!o); }
function toggleSec(evId,secId,hd)  { const e=S.events.find(x=>x.id===evId); if(!e)return; if(!e.collapsed)e.collapsed={}; const b=document.getElementById(`secbody-${evId}-${secId}`); const c=hd.querySelector('.chev'); const o=b.style.display!=='none'; b.style.display=o?'none':'block'; hd.classList.toggle('open',!o); c.classList.toggle('open',!o); e.collapsed[secId]=o; save(); }

function applyFilter() {
  const os=(document.getElementById('f-oseba')?.value||'').toLowerCase();
  const ca=(document.getElementById('f-cas')?.value||'').toLowerCase();
  const st=document.getElementById('f-status')?.value||'';
  const sc=document.getElementById('f-sec')?.value||'';
  document.querySelectorAll('tr[id^="row-"]').forEach(r=>{
    const mo=!os||(r.dataset.odgovoren||'').toLowerCase().includes(os);
    const mc=!ca||(r.dataset.cas||'').toLowerCase().includes(ca);
    const ms=!st||r.dataset.status===st;
    const mx=!sc||r.dataset.section===sc;
    r.style.display=(mo&&mc&&ms&&mx)?'':'none';
  });
}
function clearFilters() { ['f-oseba','f-cas','f-status','f-sec'].forEach(id=>{const el=document.getElementById(id); if(el)el.value='';}); applyFilter(); }

function openNewEventModal() { document.getElementById('modal-new-ev').style.display='flex'; }
function closeModal(id)      { document.getElementById(id).style.display='none'; }

function createNewEvent() {
  const name = document.getElementById('ne-name').value.trim(); if(!name){alert('Vpiši ime eventa');return;}
  const dateVal = document.getElementById('ne-date').value;
  const ev = makeDefaultEvent('ev_'+uid(), name, dateVal||'', dateVal||'', document.getElementById('ne-trajanje').value||'', document.getElementById('ne-tip').value||'', document.getElementById('ne-gostov').value||'');
  S.events.push(ev); S.currentId = ev.id; curPage = 'tasks'; save();
  closeModal('modal-new-ev'); renderSidebar(); showEvUI(); renderPage();
  ['ne-name','ne-date','ne-trajanje','ne-tip','ne-gostov'].forEach(id=>{document.getElementById(id).value='';});
  toast('Event ustvarjen ✓');
}

function deleteCurrentEvent() {
  const e = ce(); if(!e) return; if(!confirm(`Izbriši "${e.name}"?`)) return;
  S.events = S.events.filter(x => x.id!==e.id); S.currentId = S.events[0]?.id||null; save(); renderSidebar();
  if (S.currentId) { showEvUI(); renderPage(); }
  else { document.getElementById('ev-view').style.display='none'; document.getElementById('empty-state').style.display='block'; document.getElementById('page-tabs').style.display='none'; }
}

function exportCSV() {
  const e = ce(); if(!e) return;
  const sm = {}; SECTIONS.forEach(s => sm[s.id]=s.label);
  const team = e.team||[];
  let csv = '\uFEFF';
  csv += 'Sekcija,Odgovoren,Od,Do,Kaj,Status,Opombe\n';
  e.tasks.forEach(t => {
    const names = getAssigned(t).map(id=>(team.find(m=>m.id===id)||{}).name).filter(Boolean).join(', ');
    csv += [sm[t.section]||t.section, names, t.od||'', t.do||'', t.kaj, t.status, t.notes]
      .map(v=>`"${(v||'').replace(/"/g,'""')}"`).join(',') + '\n';
  });
  const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
  a.download = e.name.replace(/[^a-z0-9]/gi,'_')+'.csv'; a.click(); toast('CSV izvožen ✓');
}

let toastT;
function toast(msg) { clearTimeout(toastT); document.querySelector('.toast')?.remove(); const el=document.createElement('div'); el.className='toast'; el.textContent=msg; document.body.appendChild(el); toastT=setTimeout(()=>el.remove(),2400); }

// ── BOOT ──────────────────────────────────────────────────────────
load();
</script>
