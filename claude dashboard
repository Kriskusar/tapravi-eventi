// ═══════════════════════════════════════════════════════════════════
// CALENDAR PAGE (Časovnica)
// ═══════════════════════════════════════════════════════════════════
function renderCalendar(e) {
  const calEvents = (e.cal_events||[]).slice().sort((a,b) => t2m(a.start) - t2m(b.start));

  // Stats
  const prog   = calEvents.filter(x => x.type==='program').length;
  const checks = calEvents.filter(x => x.type==='check').length;

  // ── TYPE FILTER LEGEND ───────────────────────────────────────
  const legendHtml = Object.entries(CAL_TYPE_COLORS).map(([k,c]) => {
    const active = typeFilter[k] !== false;
    const cnt = calEvents.filter(x => x.type===k).length;
    return `<div onclick="toggleTypeFilter('${k}')" style="display:flex;align-items:center;gap:5px;font-size:11px;font-weight:700;cursor:pointer;padding:4px 10px;border-radius:20px;border:1.5px solid ${active?c:'transparent'};background:${active?`rgba(${hexRgb(c)},.18)`:'var(--surface2)'};color:${active?c:'var(--muted)'};opacity:${active?1:.55};transition:all .13s">
      <div style="width:9px;height:9px;border-radius:2px;background:${c}"></div>
      ${CAL_TYPE_LABELS[k]} ${k.charAt(0).toUpperCase()+k.slice(1)}
      <span style="font-family:'DM Mono';font-size:10px;opacity:.7">${cnt}</span>
    </div>`;
  }).join('');

  // ── BUILD TIME LABEL COLUMN (absolute, same coordinate space) ──
  // Labels sit at m2px(h*60) — the top of each hour.
  // We add a small offset (+1px) so the label reads as "this hour starts here".
  let timeLabelsHtml = '';
  let gridLinesHtml  = '';
  for (let h = CAL_START_H; h <= CAL_END_H; h++) {
    const mins  = h * 60;
    const top   = m2px(mins);
    const label = `${String(h % 24).padStart(2,'0')}:00`;
    // Label (right-aligned in time col, vertically centred on the grid line)
    timeLabelsHtml += `<div class="cal-time-label" style="top:${top}px">${label}</div>`;
    // Full-hour grid line in the events col
    if (h < CAL_END_H) {
      gridLinesHtml += `<div class="cal-grid-hour" style="top:${top}px"></div>`;
      // Half-hour dashed line
      const halfTop = m2px(mins + 30);
      gridLinesHtml += `<div class="cal-grid-half" style="top:${halfTop}px"></div>`;
    }
  }

  // ── COLLISION DETECTION → assign columns ──────────────────────
  const visible = calEvents
    .filter(ev => typeFilter[ev.type] !== false)
    .map(ev => {
      const sM = t2m(ev.start);
      const eM = endM(sM, ev.end);
      return { ...ev, sM, eM, _col:0, _totalCols:1 };
    });

  const cols = [];
  visible.forEach(ev => {
    let placed = false;
    for (let c = 0; c < cols.length; c++) {
      const last = cols[c][cols[c].length - 1];
      if (ev.sM >= last.eM) { cols[c].push(ev); ev._col = c; placed = true; break; }
    }
    if (!placed) { cols.push([ev]); ev._col = cols.length - 1; }
  });
  // Second pass: find max simultaneous columns for each event
  visible.forEach(ev => {
    let max = 1;
    visible.forEach(other => {
      if (other.id === ev.id) return;
      if (ev.sM < other.eM && ev.eM > other.sM) max = Math.max(max, other._col + 1, ev._col + 1);
    });
    ev._totalCols = max;
  });

  // ── BUILD EVENT BLOCKS ──────────────────────────────────────
  let blocksHtml = '';
  visible.forEach(ev => {
    const top    = m2px(ev.sM);
    const height = Math.max(36, m2px(ev.eM) - top);
    const color  = CAL_TYPE_COLORS[ev.type] || '#ffcb05';
    const bg     = ev.type === 'program' ? color : `rgba(${hexRgb(color)},.18)`;
    const clr    = ev.type === 'program' ? '#111' : 'var(--text)';
    const mem    = (e.team||[]).find(m => m.id === ev.person);
    const emoji  = CAL_TYPE_LABELS[ev.type] || '📌';
    const durMins = ev.eM - ev.sM;
    const wPct   = 100 / ev._totalCols;
    const lPct   = ev._col * wPct;
    blocksHtml += `<div class="cal-event-block"
      style="top:${top}px;height:${height}px;left:calc(${lPct}% + 3px);width:calc(${wPct}% - 6px);background:${bg};color:${clr};border-left-color:${color};"
      onclick="openCalEventEdit('${e.id}','${ev.id}')">
      <div class="cal-event-title">${emoji} ${escH(ev.title)}</div>
      <div class="cal-event-time">${ev.start}${ev.end?' – '+ev.end:''}</div>
      ${mem && durMins >= 20 ? `<div class="cal-event-person" style="color:${mem.color}">👤 ${mem.name}</div>` : ''}
      ${ev.notes && durMins >= 30 ? `<div class="cal-event-notes">${escH(ev.notes.slice(0,70))}${ev.notes.length>70?'…':''}</div>` : ''}
    </div>`;
  });

  // ── NOW LINE ─────────────────────────────────────────────────
  const now = new Date();
  const nowMins = now.getHours()*60 + now.getMinutes();
  const nowHtml = (nowMins >= CAL_START_H*60 && nowMins < CAL_END_H*60)
    ? `<div class="cal-now-line" style="top:${m2px(nowMins)}px" title="Zdaj: ${m2str(nowMins)}"></div>`
    : '';

  return `
  <!-- CAL HEADER -->
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:11px;font-weight:700;color:var(--muted)">DATUM:</span>
      <input style="background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-family:'DM Mono',monospace;font-size:13px;color:var(--text);outline:none;cursor:pointer;"
        type="date" value="${e.cal_date||''}" onchange="upCalDate('${e.id}',this.value)"/>
    </div>
    <div style="display:flex;gap:7px">
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Program: </span><span style="color:var(--yellow);font-weight:800;font-family:'DM Mono'">${prog}</span></div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Kontrole: </span><span style="color:#94a3b8;font-weight:800;font-family:'DM Mono'">${checks}</span></div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:11px"><span style="color:var(--muted);font-weight:700">Skupaj: </span><span style="font-weight:800;font-family:'DM Mono'">${calEvents.length}</span></div>
    </div>
    <button class="btn-sm primary" onclick="openCalSlot('${e.id}',1140)" style="margin-left:auto">＋ Dodaj vnos</button>
  </div>

  <!-- TYPE FILTER LEGEND -->
  <div style="display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;align-items:center">
    <span style="font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.5px;text-transform:uppercase">Filtri:</span>
    ${legendHtml}
  </div>

  <!-- CALENDAR GRID -->
  <div class="cal-outer">
    <!-- TIME COLUMN — height = CAL_TOTAL_PX, all labels positioned absolutely -->
    <div class="cal-time-col" style="height:${CAL_TOTAL_PX}px">
      ${timeLabelsHtml}
    </div>
    <!-- EVENTS COLUMN — same height, grid lines + event blocks absolutely positioned -->
    <div class="cal-events-col" style="height:${CAL_TOTAL_PX}px" onclick="onCalColClick(event,'${e.id}')">
      ${gridLinesHtml}
      ${nowHtml}
      ${blocksHtml}
    </div>
  </div>
  <div style="margin-top:8px;font-size:11px;color:var(--muted);text-align:center">Klikni na prazen termin za nov vnos · Klikni na blok za urejanje</div>`;
}

function toggleTypeFilter(type) { typeFilter[type] = !typeFilter[type]; renderPage(); }

// Click on empty area of events column → open new event at that time
function onCalColClick(evt, evId) {
  if (evt.target.classList.contains('cal-event-block') || evt.target.closest('.cal-event-block')) return;
  const col = evt.currentTarget;
  const rect = col.getBoundingClientRect();
  const relY = evt.clientY - rect.top + col.scrollTop;
  const mins = Math.round(relY / PX_PER_MIN / 30) * 30 + CAL_START_H * 60;
  openCalSlot(evId, Math.max(CAL_START_H*60, Math.min((CAL_END_H-1)*60, mins)));
}

function upCalDate(evId, val) { const e = S.events.find(x => x.id===evId); if(e){e.cal_date=val; save();} }

function openCalSlot(evId, mins) {
  calEditId = null; calEditType = 'program';
  const e = S.events.find(x => x.id===evId); if(!e) return;
  document.getElementById('cal-modal-title').textContent = 'Nov vnos v časovnico';
  document.getElementById('cal-ev-title').value = '';
  document.getElementById('cal-ev-start').value = m2str(mins);
  document.getElementById('cal-ev-end').value   = m2str(mins + 60);
  document.getElementById('cal-ev-notes').value = '';
  document.getElementById('cal-ev-del').style.display = 'none';
  populateCalPersonSelect(e, '');
  selectCalType('program');
  document.getElementById('modal-cal-ev').style.display = 'flex';
}

function openCalEventEdit(evId, calId) {
  const e  = S.events.find(x => x.id===evId); if(!e) return;
  const ev = (e.cal_events||[]).find(x => x.id===calId); if(!ev) return;
  calEditId = calId; calEditType = ev.type||'program';
  document.getElementById('cal-modal-title').textContent = 'Uredi vnos';
  document.getElementById('cal-ev-title').value = ev.title||'';
  document.getElementById('cal-ev-start').value = ev.start||'';
  document.getElementById('cal-ev-end').value   = ev.end||'';
  document.getElementById('cal-ev-notes').value = ev.notes||'';
  document.getElementById('cal-ev-del').style.display = 'flex';
  populateCalPersonSelect(e, ev.person||'');
  selectCalType(ev.type||'program');
  document.getElementById('modal-cal-ev').style.display = 'flex';
}

function populateCalPersonSelect(e, selId) {
  const sel = document.getElementById('cal-ev-person');
  sel.innerHTML = '<option value="">— Brez —</option>' +
    (e.team||[]).map(m => `<option value="${m.id}" ${m.id===selId?'selected':''}>${m.name}</option>`).join('');
}

function selectCalType(type) {
  calEditType = type;
  document.querySelectorAll('.type-chip').forEach(c => {
    const t = c.dataset.type;
    const col = CAL_TYPE_COLORS[t]||'#fff';
    c.style.borderColor  = t===type ? col : 'transparent';
    c.style.background   = t===type ? `rgba(${hexRgb(col)},.25)` : `rgba(${hexRgb(col)},.08)`;
    c.style.color        = col;
  });
}

function saveCalEvent() {
  const e = ce(); if(!e) return;
  if(!e.cal_events) e.cal_events = [];
  const title = document.getElementById('cal-ev-title').value.trim();
  if(!title) { alert('Vpiši naslov'); return; }
  const obj = {
    title, type: calEditType,
    start:  document.getElementById('cal-ev-start').value,
    end:    document.getElementById('cal-ev-end').value,
    notes:  document.getElementById('cal-ev-notes').value,
    person: document.getElementById('cal-ev-person').value,
  };
  if (calEditId) {
    const ev = e.cal_events.find(x => x.id===calEditId);
    if (ev) Object.assign(ev, obj);
  } else {
    e.cal_events.push({ id:uid(), ...obj });
  }
  save(); closeModal('modal-cal-ev'); renderPage(); toast('Shranjeno ✓');
}

function deleteCalEvent() {
  const e = ce(); if(!e||!calEditId) return;
  e.cal_events = (e.cal_events||[]).filter(x => x.id!==calEditId);
  save(); closeModal('modal-cal-ev'); renderPage();
}

