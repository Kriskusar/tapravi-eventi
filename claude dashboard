<!DOCTYPE html>
<html lang="sl" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Taprav — Event Manager</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ── TAPRAV BRAND COLORS ──────────────────────────────────── */
:root {
  --yellow: #ffcb05;
  --yellow-dim: #d4a804;
  --yellow-soft: rgba(255,203,5,.12);
  --yellow-glow: rgba(255,203,5,.25);
  --bg: #111111;
  --surface: #1a1a1a;
  --surface2: #222222;
  --surface3: #2a2a2a;
  --border: #2e2e2e;
  --border2: #3a3a3a;
  --text: #e8e8e8;
  --muted: #666;
  --muted2: #999;
  --ok: #22c55e;
  --danger: #ef4444;
  --warn: #f59e0b;
  --info: #38bdf8;
  --heading: #ffffff;
  --sidebar-w: 270px;
}
html[data-theme="light"] {
  --bg: #f5f4ef;
  --surface: #ffffff;
  --surface2: #f0efe8;
  --surface3: #e8e7df;
  --border: #ddd;
  --border2: #ccc;
  --text: #1a1a1a;
  --muted: #888;
  --muted2: #555;
  --heading: #111;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;font-size:14px;}

/* ── SIDEBAR ──────────────────────────────────────────────── */
#sidebar{
  width:var(--sidebar-w);min-height:100vh;
  background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;z-index:100;
  transition:transform .25s cubic-bezier(.4,0,.2,1);
}
#sidebar.hidden{transform:translateX(-100%);}
.sidebar-logo{
  padding:16px 18px 14px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
  background:var(--surface);
}
.logo-svg-wrap{
  width:165px;height:auto;flex-shrink:0;
  display:flex;align-items:center;
  background:#fff;
  border-radius:8px;
  padding:6px 8px;
}
.logo-svg-wrap svg{width:100%;height:auto;display:block;}
.sidebar-logo{padding:12px 14px 12px !important;}
.logo-sub{font-size:10px;color:var(--muted);margin-top:2px;letter-spacing:.5px;text-transform:uppercase;font-weight:600;}
.sb-scroll{flex:1;overflow-y:auto;padding:10px 0;}
.sb-lbl{font-size:9px;font-weight:700;letter-spacing:1px;color:var(--muted);padding:10px 18px 4px;text-transform:uppercase;}
.ev-item{padding:10px 18px;cursor:pointer;border-left:3px solid transparent;transition:background .13s;}
.ev-item:hover{background:var(--surface2);}
.ev-item.active{background:var(--surface2);border-left-color:var(--yellow);}
.ev-name{font-weight:700;font-size:12px;color:var(--text);line-height:1.3;}
.ev-meta{font-size:10px;color:var(--muted);margin-top:2px;}
.ev-bar{height:2px;border-radius:2px;background:var(--border);margin-top:7px;overflow:hidden;}
.ev-bar-fill{height:100%;border-radius:2px;background:var(--yellow);transition:width .4s;}
.btn-new-ev{
  margin:10px 14px;padding:10px;
  background:var(--yellow);color:#111;
  border:none;border-radius:8px;
  font-family:inherit;font-size:12px;font-weight:800;
  cursor:pointer;width:calc(100% - 28px);
  display:flex;align-items:center;justify-content:center;gap:6px;
  transition:opacity .15s,transform .1s;
  letter-spacing:.3px;
}
.btn-new-ev:hover{opacity:.88;transform:translateY(-1px);}

/* ── MAIN ────────────────────────────────────────────────── */
#main{margin-left:var(--sidebar-w);flex:1;min-height:100vh;display:flex;flex-direction:column;transition:margin-left .25s cubic-bezier(.4,0,.2,1);}
#main.full{margin-left:0;}
#topbar{
  position:sticky;top:0;z-index:50;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  padding:0 22px;height:52px;
  display:flex;align-items:center;gap:10px;
}
.btn-icon{width:32px;height:32px;border-radius:7px;background:var(--surface2);border:1px solid var(--border);color:var(--text);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;transition:background .13s;}
.btn-icon:hover{background:var(--border);}
.topbar-title{font-weight:800;font-size:14px;color:var(--heading);flex:1;letter-spacing:-.2px;}
.topbar-actions{display:flex;align-items:center;gap:6px;}
.btn-sm{padding:5px 12px;border-radius:6px;font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;border:1px solid var(--border);background:var(--surface2);color:var(--text);display:flex;align-items:center;gap:4px;transition:all .13s;white-space:nowrap;}
.btn-sm:hover{background:var(--border);}
.btn-sm.primary{background:var(--yellow);border-color:var(--yellow);color:#111;}
.btn-sm.primary:hover{opacity:.85;}
.btn-sm.danger{background:var(--danger);border-color:var(--danger);color:#fff;}

/* ── PAGE TABS ───────────────────────────────────────────── */
.page-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);background:var(--surface);padding:0 22px;overflow-x:auto;}
.ptab{padding:10px 15px;border:none;background:transparent;color:var(--muted);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;white-space:nowrap;}
.ptab:hover{color:var(--text);}
.ptab.active{color:var(--yellow);border-bottom-color:var(--yellow);}

/* ── CONTENT ─────────────────────────────────────────────── */
#content{padding:20px;flex:1;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:14px;}
.card-hd{padding:12px 16px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none;border-bottom:1px solid transparent;}
.card-hd.open{border-bottom-color:var(--border);}
.sec-title{font-weight:800;font-size:11px;letter-spacing:.8px;text-transform:uppercase;}
.sec-badge{font-size:10px;padding:2px 8px;border-radius:20px;background:var(--surface2);color:var(--muted);font-weight:700;margin-left:7px;}
.chev{transition:transform .2s;font-size:11px;color:var(--muted);}
.chev.open{transform:rotate(180deg);}

/* ── TABLES ──────────────────────────────────────────────── */
.stbl{width:100%;border-collapse:collapse;}
.stbl thead th{padding:8px 12px;font-size:9px;font-weight:700;letter-spacing:.9px;text-transform:uppercase;color:var(--muted);background:var(--surface2);text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;}
.stbl tbody tr{border-bottom:1px solid var(--border);transition:background .1s;}
.stbl tbody tr:last-child{border-bottom:none;}
.stbl tbody tr:hover{background:var(--surface2);}
.stbl tbody td{padding:7px 12px;vertical-align:middle;font-size:12px;color:var(--text);}
.editable{background:transparent;border:none;outline:none;font-family:inherit;font-size:12px;color:var(--text);width:100%;resize:none;min-height:18px;border-radius:4px;padding:2px 4px;transition:background .13s;}
.editable:focus{background:var(--surface2);outline:1px solid var(--yellow);}
input.editable{height:24px;}
textarea.editable{min-height:22px;overflow:hidden;}
.ssel{background:transparent;border:none;outline:none;font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;border-radius:20px;padding:3px 10px;-webkit-appearance:none;transition:all .13s;}
.s-todo{background:rgba(102,102,102,.15);color:var(--muted);}
.s-inprogress{background:rgba(255,203,5,.15);color:var(--yellow-dim);}
.s-done{background:rgba(34,197,94,.15);color:var(--ok);}
.s-blocked{background:rgba(239,68,68,.15);color:var(--danger);}

/* ── PERSON PICKER ───────────────────────────────────────── */
.pcell{position:relative;}
.pbtn{background:transparent;border:none;cursor:pointer;font-family:inherit;font-size:12px;color:var(--text);width:100%;text-align:left;padding:2px 4px;border-radius:4px;display:flex;align-items:center;gap:5px;transition:background .13s;min-height:24px;}
.pbtn:hover{background:var(--surface2);}
.pavatar{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#111;flex-shrink:0;background:var(--yellow);}
.pempty{color:var(--muted);font-size:11px;}
.pdrop{position:absolute;top:100%;left:0;z-index:500;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:6px;min-width:165px;box-shadow:0 8px 32px rgba(0,0,0,.5);display:none;}
.pdrop.open{display:block;}
.pd-item{display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:6px;cursor:pointer;transition:background .12s;}
.pd-item:hover{background:var(--surface2);}
.pd-item span{font-size:12px;font-weight:600;}
.pd-clear{display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:11px;color:var(--muted);border-top:1px solid var(--border);margin-top:4px;}
.pd-clear:hover{color:var(--danger);}

/* ── INFO TABLE ──────────────────────────────────────────── */
.info-tbl{width:100%;border-collapse:collapse;}
.info-tbl tr{border-bottom:1px solid var(--border);}
.info-tbl tr:last-child{border-bottom:none;}
.info-tbl td{padding:9px 16px;}
.info-tbl td:first-child{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--yellow);width:200px;white-space:nowrap;}

/* ── STATS ───────────────────────────────────────────────── */
.stat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:16px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:14px 16px;}
.stat-lbl{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);}
.stat-val{font-size:26px;font-weight:800;color:var(--heading);margin-top:3px;letter-spacing:-1px;font-family:'DM Mono',monospace;}
.stat-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.pbar-wrap{height:6px;border-radius:3px;background:var(--border);overflow:hidden;flex:1;}
.pbar-fill{height:100%;border-radius:3px;background:var(--yellow);transition:width .5s;}

/* ── FILTER BAR ──────────────────────────────────────────── */
.filter-bar{display:flex;align-items:center;gap:7px;margin-bottom:12px;flex-wrap:wrap;}
.filter-input{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:6px 11px;font-family:inherit;font-size:12px;color:var(--text);outline:none;transition:border-color .13s;}
.filter-input:focus{border-color:var(--yellow);}

/* ── BUTTONS ─────────────────────────────────────────────── */
.btn-add-row{display:flex;align-items:center;gap:5px;padding:7px 14px;font-size:11px;font-weight:700;color:var(--yellow);cursor:pointer;border:none;background:transparent;font-family:inherit;transition:background .13s;border-radius:0 0 9px 9px;width:100%;}
.btn-add-row:hover{background:var(--surface2);}
.del-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:13px;padding:2px 4px;border-radius:4px;line-height:1;transition:color .13s,background .13s;}
.del-btn:hover{color:var(--danger);background:rgba(239,68,68,.1);}

/* ── SECTION COLORS ──────────────────────────────────────── */
.c-admin{color:#ffcb05;}.c-prostor{color:#a78bfa;}.c-scena{color:#f472b6;}
.c-pijaca{color:#22d3ee;}.c-hrana{color:#fb923c;}.c-nastopajoci{color:#4ade80;}
.c-tiskovine{color:#f87171;}.c-promocija{color:#c084fc;}.c-post{color:#94a3b8;}

/* ── COST / NABAVA ───────────────────────────────────────── */
.cost-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.cost-card{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:14px 16px;}
.cost-lbl{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);}
.cost-val{font-size:22px;font-weight:800;font-family:'DM Mono',monospace;margin-top:4px;}

/* ── DAILY CALENDAR (ČASOVNICA) ──────────────────────────── */
.cal-wrap{display:flex;gap:0;overflow-x:auto;}
.cal-time-col{width:60px;flex-shrink:0;}
.cal-day-col{flex:1;min-width:0;position:relative;}
.cal-slot{height:60px;border-bottom:1px solid var(--border);position:relative;}
.cal-slot.half{height:30px;border-bottom:1px dashed var(--border);opacity:.6;}
.cal-time-label{height:30px;display:flex;align-items:flex-start;padding-top:2px;padding-right:12px;font-size:10px;font-weight:700;color:var(--muted);font-family:'DM Mono',monospace;justify-content:flex-end;position:relative;}
.cal-time-label.half{height:30px;font-size:9px;color:var(--border2);opacity:.6;}
.cal-event-block{
  position:absolute;left:4px;right:4px;
  border-radius:6px;padding:5px 8px;
  font-size:11px;font-weight:700;
  cursor:pointer;overflow:hidden;
  box-shadow:0 2px 8px rgba(0,0,0,.25);
  transition:opacity .13s,transform .1s;
  z-index:10;
  border-left:3px solid rgba(0,0,0,.2);
}
.cal-event-block:hover{opacity:.9;transform:scale(1.01);}
.cal-event-title{font-weight:800;font-size:11px;line-height:1.2;}
.cal-event-person{font-size:10px;opacity:.8;margin-top:2px;}
.cal-event-notes{font-size:10px;opacity:.7;margin-top:2px;font-weight:400;}
.cal-now-line{position:absolute;left:0;right:0;height:2px;background:var(--yellow);z-index:20;pointer-events:none;}
.cal-now-line::before{content:'';position:absolute;left:-4px;top:-4px;width:10px;height:10px;border-radius:50%;background:var(--yellow);}
/* Checklist items in timeline */
.cal-check-block{
  position:absolute;left:4px;right:4px;
  border-radius:6px;padding:4px 8px;
  font-size:10px;font-weight:600;
  background:var(--surface3);
  border:1px solid var(--border2);
  border-left:3px solid var(--muted);
  cursor:pointer;
  transition:opacity .13s;
  z-index:10;
}
.cal-check-block.done-check{opacity:.5;text-decoration:line-through;}
.cal-add-btn{
  position:absolute;left:4px;right:4px;
  display:flex;align-items:center;justify-content:center;
  color:var(--yellow);font-size:18px;
  cursor:pointer;opacity:0;transition:opacity .15s;
}
.cal-slot:hover .cal-add-btn{opacity:.5;}
.cal-header{display:flex;align-items:center;gap:12px;margin-bottom:14px;flex-wrap:wrap;}
.cal-date-input{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-family:'DM Mono',monospace;font-size:13px;color:var(--text);outline:none;cursor:pointer;}
.cal-date-input:focus{border-color:var(--yellow);}
.cal-type-btn{padding:5px 12px;border-radius:6px;border:1px solid var(--border);background:var(--surface2);color:var(--muted);font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;transition:all .13s;}
.cal-type-btn.active{background:var(--yellow);border-color:var(--yellow);color:#111;}

/* Event edit modal in calendar */
.cal-modal{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;width:400px;max-width:95vw;}
.cal-modal h4{font-size:14px;font-weight:800;color:var(--heading);margin-bottom:14px;}
.type-picker{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
.type-chip{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid transparent;transition:all .13s;}
.color-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:4px;}
.cchip{width:20px;height:20px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .1s;}
.cchip:hover{transform:scale(1.2);}
.cchip.sel{border-color:white;}

/* ── TEAM MODAL ──────────────────────────────────────────── */
.team-tbl{width:100%;border-collapse:collapse;}
.team-tbl thead th{padding:8px 12px;font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);background:var(--surface2);text-align:left;border-bottom:1px solid var(--border);}
.team-tbl tbody tr{border-bottom:1px solid var(--border);}
.team-tbl tbody tr:last-child{border-bottom:none;}
.team-tbl tbody tr:hover{background:var(--surface2);}
.team-tbl tbody td{padding:8px 12px;font-size:13px;}
.cswatch{width:17px;height:17px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .1s;display:inline-block;}
.cswatch:hover{transform:scale(1.2);}
.cswatch.sel{border-color:white;}

/* ── MODAL ───────────────────────────────────────────────── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(5px);}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:26px;width:480px;max-width:95vw;max-height:92vh;overflow-y:auto;}
.modal h3{font-size:15px;font-weight:800;color:var(--heading);margin-bottom:18px;}
.form-g{margin-bottom:12px;}
.form-lbl{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);margin-bottom:5px;display:block;}
.form-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:8px 11px;font-family:inherit;font-size:13px;color:var(--text);outline:none;transition:border-color .13s;}
.form-input:focus{border-color:var(--yellow);}
.modal-actions{display:flex;gap:7px;justify-content:flex-end;margin-top:18px;}
.empty-state{text-align:center;padding:60px;color:var(--muted);}
.toast{position:fixed;bottom:18px;right:18px;z-index:9999;background:var(--yellow);color:#111;border-radius:9px;padding:10px 18px;font-size:12px;font-weight:800;box-shadow:0 8px 32px rgba(0,0,0,.4);animation:sIn .3s ease;display:flex;align-items:center;gap:7px;}
@keyframes sIn{from{transform:translateY(16px);opacity:0}to{transform:translateY(0);opacity:1}}
::-webkit-scrollbar{width:5px;height:5px;}::-webkit-scrollbar-track{background:transparent;}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
/* ── PERSON PORTAL (fixed overlay, never clipped) ────────── */
#person-portal{
  position:fixed;z-index:9000;
  background:var(--surface);border:1.5px solid var(--border2);
  border-radius:10px;padding:6px;min-width:180px;max-width:240px;
  box-shadow:0 12px 44px rgba(0,0,0,.6);
  display:none;max-height:320px;overflow-y:auto;
}
#person-portal.open{display:block;}
#sidebar-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:150;}
#sidebar-backdrop.visible{display:block;}

/* ── MOBILE RESPONSIVE ───────────────────────────────────── */
@media(max-width:768px){
  :root{--sidebar-w:0px;}
  #sidebar{transform:translateX(-100%);width:280px;z-index:200;box-shadow:0 0 40px rgba(0,0,0,.5);}
  #sidebar.mobile-open{transform:translateX(0);}
  #main{margin-left:0!important;}
  .stat-grid{grid-template-columns:repeat(2,1fr)!important;}
  .cost-summary{grid-template-columns:repeat(2,1fr)!important;}
  #topbar{padding:0 10px;gap:6px;height:48px;}
  .topbar-title{font-size:12px;letter-spacing:0;}
  .topbar-actions{gap:3px;}
  .btn-sm{padding:4px 8px;font-size:10px;}
  #content{padding:10px;}
  .page-tabs{padding:0 8px;}
  .ptab{padding:8px 8px;font-size:10px;}
  /* Card tables → stacked cards */
  .stbl{display:block;}
  .stbl thead{display:none;}
  .stbl tbody{display:block;}
  .stbl tbody tr{display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:10px;border:1px solid var(--border);border-radius:9px;margin-bottom:8px;background:var(--surface2);}
  .stbl tbody td{display:flex;flex-direction:column;padding:3px 4px;border:none;font-size:12px;}
  .stbl tbody td::before{content:attr(data-label);font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;}
  .stbl tbody td:nth-child(4){grid-column:1/-1;}
  .stbl tbody td:last-child{grid-column:1/-1;flex-direction:row;justify-content:flex-end;}
  .info-tbl td:first-child{width:130px;font-size:9px;}
  .logo-svg-wrap{width:120px!important;}
  .sidebar-logo{padding:10px 12px!important;}
  .cal-event-notes{display:none;}
  .cal-event-person{display:none;}
}
@media(max-width:480px){
  .stat-grid{grid-template-columns:repeat(2,1fr)!important;gap:6px;}
  .stat-val{font-size:20px!important;}
  .topbar-actions>.btn-sm:not(.danger):not(:last-child){display:none;}
  .topbar-actions>#mob-menu-btn{display:flex;}
}
</style>
</head>
<body>

<!-- ═══ SIDEBAR ═══ -->
<nav id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-svg-wrap">
      <svg id="a" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 960 540">
