// ═══ FILTER ═══
function applyFilter(){
  const os=(document.getElementById('f-oseba')?.value||'').toLowerCase();
  const ca=(document.getElementById('f-cas')?.value||'').toLowerCase();
  const st=document.getElementById('f-status')?.value||'';
  const sc=document.getElementById('f-sec')?.value||'';
  document.querySelectorAll('tr[id^="row-"]').forEach(r=>{
    const mo=!os||(r.dataset.odgovoren||'').toLowerCase().includes(os);
    const mc=!ca||(r.dataset.cas||'').toLowerCase().includes(ca);
    const ms=!st||r.dataset.status===st;
    const mx=!sc||r.dataset.section===sc;
    r.style.display=(mo&&mc&&ms&&mx)?'':'none';
  });
}
function clearFilters(){['f-oseba','f-cas','f-status','f-sec'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});applyFilter();}

