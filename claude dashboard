// STROŠKI
// ═══════════════════════════════════════════════════════════════════
function renderStroski(e) {
  const items      = e.stroski||[];
  const nabH       = (e.nabava_hrana||[]).reduce((s,i)  => s+parseFloat(i.cena_skupaj||0), 0);
  const nabP       = (e.nabava_pijaca||[]).reduce((s,i) => s+parseFloat(i.cena_skupaj||0), 0);
  const ostali     = items.reduce((s,i) => s+parseFloat(i.znesek||0), 0);
  const skupaj     = ostali + nabH + nabP;

  const poKat = {};
  STROSEK_KAT.forEach(k => poKat[k] = 0);
  items.forEach(i => { if(i.kategorija) poKat[i.kategorija] = (poKat[i.kategorija]||0) + parseFloat(i.znesek||0); });
  // Add nabava into their categories
  poKat['HRANA']  = (poKat['HRANA']||0)  + nabH;
  poKat['PIJAČA'] = (poKat['PIJAČA']||0) + nabP;
  const topKat = Object.entries(poKat).filter(([,v]) => v > 0).sort((a,b) => b[1]-a[1]);

  return `
  <div class="cost-summary" style="grid-template-columns:repeat(4,1fr)">
    <div class="cost-card"><div class="cost-lbl">SKUPAJ VSE</div><div class="cost-val" style="color:var(--danger)">${skupaj.toFixed(2)} €</div></div>
    <div class="cost-card"><div class="cost-lbl">Ost. stroški</div><div class="cost-val" style="color:var(--warn)">${ostali.toFixed(2)} €</div></div>
    <div class="cost-card"><div class="cost-lbl">Nabava hrana</div><div class="cost-val" style="color:#fb923c">${nabH.toFixed(2)} €</div></div>
    <div class="cost-card"><div class="cost-lbl">Nabava pijača</div><div class="cost-val" style="color:#22d3ee">${nabP.toFixed(2)} €</div></div>
  </div>
  ${topKat.length ? `<div class="card" style="margin-bottom:14px"><div class="card-hd open" style="cursor:default"><span class="sec-title" style="color:var(--danger)">PO KATEGORIJI</span></div>
    <div style="padding:12px 16px;display:flex;flex-wrap:wrap;gap:8px">
      ${topKat.map(([k,v])=>`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px"><span style="color:var(--muted);font-size:10px;font-weight:700;display:block">${k}</span><span style="font-weight:800;color:var(--danger);font-family:'DM Mono',monospace">${v.toFixed(2)} €</span></div>`).join('')}
    </div></div>` : ''}
  <div class="card"><div class="card-hd open" style="cursor:default">
    <span class="sec-title" style="color:var(--danger)">💰 STROŠKI EVENTA</span>
    <button class="btn-sm primary" onclick="addStrosek('${e.id}')">＋ Dodaj strošek</button>
  </div><div>
    <table class="stbl" id="str-tbl">
      <thead><tr>
        <th>OPIS</th><th style="width:155px">KATEGORIJA</th><th style="width:110px">ZNESEK (€)</th>
        <th style="width:110px">DATUM</th><th style="width:130px">DOBAVITELJ</th>
        <th style="width:75px;text-align:center">PLAČANO</th><th>OPOMBE</th><th style="width:28px"></th>
      </tr></thead>
      <tbody>${items.map(i => renderStrosekRow(e.id, i)).join('')}</tbody>
    </table>
  </div></div>`;
}

function renderStrosekRow(evId, i) {
  const kOpts = STROSEK_KAT.map(k => `<option value="${k}" ${i.kategorija===k?'selected':''}>${k}</option>`).join('');
  return `<tr id="srow-${i.id}">
