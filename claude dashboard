function openNewEventModal(){document.getElementById('modal-new-ev').style.display='flex';}
function closeModal(id){document.getElementById(id).style.display='none';}
function createNewEvent(){
  const name=document.getElementById('ne-name').value.trim();if(!name){alert('Vpiši ime eventa');return;}
  const dateVal=document.getElementById('ne-date').value;
  const newEv={id:'ev_'+uid(),name,podatki:{narocnik:'Taprav d.o.o',datum:dateVal||'',trajanje:document.getElementById('ne-trajanje').value||'',tip:document.getElementById('ne-tip').value||'',gostov:document.getElementById('ne-gostov').value||'',kontakt:'',telefon:'',hrana:'',pijaca:'',program:'',posebne:'',opombe:''},collapsed:{},tasks:makeTasks(),nabava_hrana:makeNH(),nabava_pijaca:makeNP(),stroski:[],team:JSON.parse(JSON.stringify(DEFAULT_TEAM)),cal_events:JSON.parse(JSON.stringify(DEFAULT_CAL_EVENTS)),cal_date:dateVal||''};
  S.events.push(newEv);S.currentId=newEv.id;curPage='tasks';save();closeModal('modal-new-ev');renderSidebar();showEvUI();renderPage();
  ['ne-name','ne-date','ne-trajanje','ne-tip','ne-gostov'].forEach(id=>{document.getElementById(id).value='';});
  toast('Event ustvarjen ✓');
}
function deleteCurrentEvent(){
  const e=ce();if(!e)return;if(!confirm(`Izbriši "${e.name}"?`))return;
  S.events=S.events.filter(x=>x.id!==e.id);S.currentId=S.events[0]?.id||null;save();renderSidebar();
  if(S.currentId){showEvUI();renderPage();}
  else{document.getElementById('ev-view').style.display='none';document.getElementById('empty-state').style.display='block';document.getElementById('page-tabs').style.display='none';}
}

// ═══ EXPORT ═══
function exportCSV(){
  const e=ce();if(!e)return;
  let csv='\uFEFF';
  csv+='Sekcija,Odgovoren,Od,Do,Kaj,Status,Opombe\n';
  const sm={};SECTIONS.forEach(s=>sm[s.id]=s.label);
  const team=e.team||[];
  e.tasks.forEach(t=>{
    const arr=getOdgovornArr(t);
    const names=arr.map(id=>(team.find(m=>m.id===id)||{}).name).filter(Boolean).join(', ');
    csv+=[sm[t.section]||t.section,names,t.od||'',t.do||'',t.kaj,t.status,t.notes].map(v=>`"${(v||'').replace(/"/g,'""')}"`).join(',')+'\n';
  });
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=e.name.replace(/[^a-z0-9]/gi,'_')+'.csv';a.click();toast('CSV izvožen ✓');
}

