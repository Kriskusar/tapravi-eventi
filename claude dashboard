// ═══ UPDATE ═══
function upPodatki(evId,key,val){const e=S.events.find(x=>x.id===evId);if(!e)return;if(!e.podatki)e.podatki={};e.podatki[key]=val;save();renderSidebar();toast('Shranjeno ✓');}
function upTask(evId,tId,field,val){const e=S.events.find(x=>x.id===evId);if(!e)return;const t=e.tasks.find(x=>x.id===tId);if(!t)return;t[field]=val;save();const row=document.getElementById('row-'+tId);if(row&&field==='od')row.dataset.cas=val;}
function upStatus(evId,tId,sel){const e=S.events.find(x=>x.id===evId);if(!e)return;const t=e.tasks.find(x=>x.id===tId);if(!t)return;t.status=sel.value;sel.className='ssel '+({todo:'s-todo',inprogress:'s-inprogress',done:'s-done',blocked:'s-blocked'}[sel.value]||'s-todo');const row=document.getElementById('row-'+tId);if(row)row.dataset.status=sel.value;save();refreshStats(evId);}
function refreshStats(evId){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const p=pct(e),done=e.tasks.filter(t=>t.status==='done').length,inp=e.tasks.filter(t=>t.status==='inprogress').length,blk=e.tasks.filter(t=>t.status==='blocked').length,tot=e.tasks.length;
  const V=document.querySelectorAll('.stat-val');if(V[0])V[0].textContent=p+'%';if(V[1])V[1].textContent=inp;if(V[2])V[2].textContent=blk;if(V[3])V[3].textContent=tot;
  const sub=document.querySelectorAll('.stat-sub');if(sub[0])sub[0].textContent=done+'/'+tot+' nalog';
  const fill=document.querySelector('.pbar-fill');if(fill)fill.style.width=p+'%';
  renderSidebar();
  SECTIONS.forEach(s=>{const b=document.querySelector(`#card-${evId}-${s.id} .sec-badge`);if(b){const st=e.tasks.filter(t=>t.section===s.id);b.textContent=st.filter(t=>t.status==='done').length+'/'+st.length;}});
}
function addTask(evId,secId){const e=S.events.find(x=>x.id===evId);if(!e)return;const t={id:uid(),section:secId,odgovoren:[],od:'',do:'',kaj:'Nova naloga',status:'todo',notes:''};e.tasks.push(t);save();const tbody=document.querySelector(`#tbl-${evId}-${secId} tbody`);if(tbody)tbody.insertAdjacentHTML('beforeend',renderRow(evId,t,e.team||[]));refreshStats(evId);}
function delTask(evId,tId){const e=S.events.find(x=>x.id===evId);if(!e)return;e.tasks=e.tasks.filter(t=>t.id!==tId);const r=document.getElementById('row-'+tId);if(r)r.remove();save();refreshStats(evId);}
// ── REAL-TIME SUMMARY HELPERS ──────────────────────────────
function refreshNabavaSummary(evId, tip){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const items = tip==='hrana' ? (e.nabava_hrana||[]) : (e.nabava_pijaca||[]);
  const nar = items.filter(i=>i.naroceno).length;
  const dos = items.filter(i=>i.dostavljeno).length;
  const skupaj = items.reduce((s,i)=>s+parseFloat(i.cena_skupaj||0),0);
  const cards = document.querySelectorAll('.cost-val');
  if(cards[0]) cards[0].textContent = skupaj.toFixed(2)+' €';
  if(cards[1]) cards[1].textContent = nar+'/'+items.length;
  if(cards[2]) cards[2].textContent = dos+'/'+items.length;
}
function refreshStroskiSummary(evId){
  const e=S.events.find(x=>x.id===evId);if(!e)return;
  const items = e.stroski||[];
  const skupaj = items.reduce((s,i)=>s+parseFloat(i.znesek||0),0);
  const cards = document.querySelectorAll('.cost-val');
  if(cards[0]) cards[0].textContent = skupaj.toFixed(2)+' €';
  if(cards[1]) cards[1].textContent = items.length;
  // Re-render "po kategoriji" block since categories shift when znesek or kategorija changes
  const e2=S.events.find(x=>x.id===evId);
  const poKat={};STROSEK_KAT.forEach(k=>poKat[k]=0);
  (e2.stroski||[]).forEach(i=>{if(i.kategorija)poKat[i.kategorija]=(poKat[i.kategorija]||0)+parseFloat(i.znesek||0);});
  const topKat=Object.entries(poKat).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);
  // Find existing kategorija card (if any) and update in-place
  const stroskiView = document.getElementById('ev-view');
  if(stroskiView){
    // find the card right before #str-tbl parent
    const existing = stroskiView.querySelector('.card:first-of-type + .card, .card:first-of-type');
    // Simpler: just regenerate the per-category section HTML
    let katHtml = '';
    if(topKat.length){
      katHtml = `<div class="card" id="kat-card" style="margin-bottom:14px"><div class="card-hd" style="cursor:default"><span class="sec-title" style="color:var(--danger)">PO KATEGORIJI</span></div>
        <div style="padding:12px 16px;display:flex;flex-wrap:wrap;gap:8px">
          ${topKat.map(([k,v])=>`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px"><span style="color:var(--muted);font-size:10px;font-weight:700;display:block">${k}</span><span style="font-weight:800;color:var(--danger);font-family:'DM Mono',monospace">${v.toFixed(2)} €</span></div>`).join('')}
        </div></div>`;
    }
    const katEl = document.getElementById('kat-card');
    if(katEl) katEl.outerHTML = katHtml;
    else if(katHtml){
      // Insert after cost-summary
      const summary = stroskiView.querySelector('.cost-summary');
      if(summary) summary.insertAdjacentHTML('afterend', katHtml);
    }
  }
}

